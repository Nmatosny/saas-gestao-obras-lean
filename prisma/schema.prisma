// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  password      String?
  image         String?
  role          String    @default("USER")
  workspaceId   String
  workspace     Workspace @relation(fields: [workspaceId], references: [id])
  measurements  MeasurementAudit[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @default(now()) @updatedAt
}

model Workspace {
  id        String   @id @default(cuid())
  name      String
  users     User[]
  obras     Obra[]
  resources   Resource[]
  createdAt   DateTime @default(now())
}

model Obra {
  id          String      @id @default(cuid())
  nome        String
  descricao   String?
  endereco    String?
  engenheiro  String?
  arquiteto   String?
  status      String      @default("planejada")
  progress    Float       @default(0)
  workspaceId String
  workspace   Workspace   @relation(fields: [workspaceId], references: [id])
  atividades  Atividade[]
  diarios     Diario[]
  locais      Location[]
  servicos    Service[]
  versoes     CronogramaVersao[]
  measurements MeasurementAudit[]
  createdAt   DateTime    @default(now())

  @@index([workspaceId])
}

model Atividade {
  id              String      @id @default(cuid())
  name            String
  startDate       DateTime
  endDate         DateTime
  baselineInicio  DateTime?
  baselineFim     DateTime?
  progress        Float       @default(0)
  weight          Float       @default(1)
  status          String      @default("planejado")
  isCritical      Boolean     @default(false)
  
  // WBS / Hierarchy
  wbs             String?
  outlineLevel    Int         @default(0)
  isSummary       Boolean     @default(false)
  parentId        String?
  parent          Atividade?  @relation("AtividadeHierarchy", fields: [parentId], references: [id])
  children        Atividade[] @relation("AtividadeHierarchy")

  // Medição Acumulada
  quantidadeTotal Float?
  unidadeMedida   String?
  quantidadeRealizada Float   @default(0)

  causaNaoCumprimento String?
  impactoDescricao    String?
  
  // Financeiro / ERP Integration
  budgetedCost        Float       @default(0)
  actualCost          Float       @default(0)
  externalId          String?     // Chave de integração com ERP
  
  serviceId       String
  service         Service     @relation(fields: [serviceId], references: [id])
  locationId      String
  location        Location    @relation(fields: [locationId], references: [id])
  obraId          String
  obra            Obra        @relation(fields: [obraId], references: [id])
  
  predecessors    Dependency[] @relation("PredecessorAtiv")
  sucessors       Dependency[] @relation("SucessorAtiv")
  
  resourceId      String?
  resource        Resource?    @relation(fields: [resourceId], references: [id])
  
  diarioAtivs     DiarioAtividade[]
  restricoes      Restricao[]
  measurements    MeasurementAudit[]
  createdAt       DateTime    @default(now())

  @@index([obraId])
  @@index([serviceId])
  @@index([locationId])
}

model Location {
  id          String      @id @default(cuid())
  name        String
  obraId      String
  obra        Obra        @relation(fields: [obraId], references: [id])
  atividades  Atividade[]

  @@index([obraId])
}

model Service {
  id             String      @id @default(cuid())
  name           String
  color          String      @default("#000000")
  custoEstimado  Float?
  obraId         String
  obra           Obra        @relation(fields: [obraId], references: [id])
  atividades     Atividade[]
  predecessores  DependenciaServico[] @relation("Sucessor")
  sucessores     DependenciaServico[] @relation("Predecessor")

  @@index([obraId])
}

model Dependency {
  id              String    @id @default(cuid())
  obraId          String
  predecessorId   String
  sucessorId      String
  type            String    @default("FS") // FS, SS, FF, SF
  lag             Int       @default(0)
  
  predecessor     Atividade @relation("PredecessorAtiv", fields: [predecessorId], references: [id])
  sucessor        Atividade @relation("SucessorAtiv", fields: [sucessorId], references: [id])

  @@index([obraId])
  @@index([predecessorId])
  @@index([sucessorId])
}

model Restricao {
  id          String    @id @default(cuid())
  descricao   String
  status      String    @default("aberta") // aberta, resolvida
  dataResolucao DateTime?
  atividadeId String
  atividade   Atividade @relation(fields: [atividadeId], references: [id])

  @@index([atividadeId])
}

model CronogramaVersao {
  id          String   @id @default(cuid())
  nome        String
  descricao   String?
  data        DateTime @default(now())
  obraId      String
  obra        Obra     @relation(fields: [obraId], references: [id])
  snapshot    String?  
  createdAt   DateTime @default(now())

  @@index([obraId])
}

model Diario {
  id               String            @id @default(cuid())
  date             DateTime
  weatherMorning   String?
  weatherAfternoon String?
  weatherNight     String?
  notes            String?
  ocorrencias      String?           // JSON String
  equipamentos     String?           // JSON String
  obra             Obra              @relation(fields: [obraId], references: [id])
  obraId           String
  atividades       DiarioAtividade[]
  efetivos         Efetivo[]
  fotos            Foto[]
  createdAt        DateTime          @default(now())

  @@unique([obraId, date])
  @@index([obraId])
}

model DiarioAtividade {
  id                    String    @id @default(cuid())
  diario                Diario    @relation(fields: [diarioId], references: [id])
  diarioId              String
  atividade             Atividade @relation(fields: [atividadeId], references: [id])
  atividadeId           String
  progress              Float
  quantidadeRealizada   Float     @default(0)
  status                String?
  quantidadeTrabalhadores Int     @default(0)
  fotosAtividade        String?   // JSON array of {url, caption}
  actualManHours        Float?    // Hours spent by the resource in this entry
  cost                  Float     @default(0) // Financial cost of this entry
  apontamentos          Apontamento[]

  @@index([diarioId])
  @@index([atividadeId])
}

model Efetivo {
  id           String        @id @default(cuid())
  role         String
  count        Int
  diario       Diario        @relation(fields: [diarioId], references: [id])
  diarioId     String
  apontamentos Apontamento[]

  @@index([diarioId])
}

model Apontamento {
  id                String          @id @default(cuid())
  efetivo           Efetivo         @relation(fields: [efetivoId], references: [id])
  efetivoId         String
  diarioAtividade   DiarioAtividade @relation(fields: [diarioAtividadeId], references: [id])
  diarioAtividadeId String

  @@index([efetivoId])
  @@index([diarioAtividadeId])
}

model DependenciaServico {
  id                   String  @id @default(cuid())
  obraId               String
  servicoPredecessorId String
  servicoSucessorId    String
  lagDias              Int     @default(0)

  servicoPredecessor   Service @relation("Predecessor", fields: [servicoPredecessorId], references: [id])
  servicoSucessor      Service @relation("Sucessor", fields: [servicoSucessorId], references: [id])

  @@index([obraId])
}

model Foto {
  id        String   @id @default(cuid())
  url       String
  caption   String?
  diario    Diario   @relation(fields: [diarioId], references: [id])
  diarioId  String
  createdAt DateTime @default(now())

  @@index([diarioId])
}

model MeasurementAudit {
  id              String    @id @default(cuid())
  atividadeId     String
  obraId          String
  userId          String
  oldProgress     Float
  newProgress     Float
  oldQuantity     Float?
  newQuantity     Float?
  source          String    @default("RDO") // RDO, MANUAL, API
  createdAt       DateTime  @default(now())

  atividade       Atividade @relation(fields: [atividadeId], references: [id], onDelete: Cascade)
  obra            Obra      @relation(fields: [obraId], references: [id], onDelete: Cascade)
  user            User      @relation(fields: [userId], references: [id])

  @@index([atividadeId])
  @@index([userId])
}

model Resource {
  id            String      @id @default(cuid())
  name          String
  type          String      @default("EMPREITEIRA") // EMPREITEIRA, FUNCIONARIO
  role          String?     // Pedreiro, Eletricista, etc.
  companyName   String?     // For contractors
  hourlyRate    Float       @default(0)
  workspaceId   String
  workspace     Workspace   @relation(fields: [workspaceId], references: [id])
  atividades    Atividade[]
  createdAt     DateTime    @default(now())

  @@index([workspaceId])
}
